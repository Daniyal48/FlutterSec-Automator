  //    Method        : {{ offset.method }}
  //    Arch          : {{ offset.arch }}
  //    Virtual Addr  : 0x{{ '%08x' | format(offset.virtual_address) }}
  //    bypass_return : {{ offset.bypass_return }}  ({{ offset.return_type }})
