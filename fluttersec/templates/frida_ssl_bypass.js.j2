    // base + virtual_address gives the correct runtime address.
    // Using file_offset here would be WRONG: file offsets include ELF headers
    // that are not present in the process memory map.
    var targetAddr = base.add(0x{{ '%x' | format(offset.virtual_address) }});
    try {
      Interceptor.replace(
        targetAddr,
        new NativeCallback(
          function () {
{% if offset.return_type == "void" %}
